                      "});",
                      "",
                      "// 2. Проверяем текст ответа",
                      "pm.test(\"Подтверждение удаления товара\", function () {",
                      "    pm.expect(pm.response.json()).to.eql(true);",
                      "});"
                    ],
                    "type": "text/javascript",
