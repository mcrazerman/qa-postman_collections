    {
      "name": "Positive cases",
      "item": [
        {
          "name": "products",
          "item": [
            {
              "name": "Create a product",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "//1. Проверяем статус код",
                      "pm.test(\"Статус-код должен быть 201 Created\", function () {",
                      "    pm.response.to.have.status(201);",
                      "});",
                      "",
                      "// 2. Проверяем время ответа сервера",
                      "pm.test(\"Время ответа должно быть менее 800 мс\", function () {",
                      "    pm.expect(pm.response.responseTime).to.be.below(800);",
                      "});",
                      "",
                      "// 3. Валидируем структуру и данные ответа",
                      "const responseJson = pm.response.json();",
                      "const requestBody = JSON.parse(pm.request.body.raw);",
                      "pm.test(\"Ответ должен содержать поле 'id'\", function () {",
                      "    pm.expect(responseJson).to.have.property('id');",
                      "    pm.expect(responseJson.id).to.be.a('number');",
                      "});",
                      "",
                      "pm.test(\"Данные товара соответствуют отправленным\", function() {",
                      "    pm.expect(responseJson.title).to.equal(requestBody.title);",
                      "    pm.expect(responseJson.description).to.equal(requestBody.description);",
                      "    pm.expect(responseJson.price).to.equal(requestBody.price);",
                      "    pm.expect(responseJson.category.id).to.equal(requestBody.categoryId)",
                      "    pm.expect(responseJson.images).to.eql(requestBody.images);",
                      "});",
                      "",
                      "// 4. Динамическое связывание: сохраняем ID созданного товара в переменную коллекции,",
                      "// чтобы следующий GET-запрос использовал именно его",
                      "if (responseJson.id){",
                      "    pm.collectionVariables.set(\"createdProductId\", responseJson.id);",
                      "}"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json",
                    "type": "text"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n    \"title\": \"Tennis racket\",   \n    \"price\": 30,   \n    \"description\": \"Very good\",\n    \"categoryId\": 1, \n    \"images\": [\n        \"https://placehold.co/600x400\"\n     ] \n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                },
                "url": {
                  "raw": "{{baseUrl}}/products",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "products"
                  ]
                }
              },
              "response": []
            },
            {
              "name": "Get a product by id",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status code is 200\", function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "// 2. Проверяем, что вернулся именно тот товар, который мы создали",
                      "const responseJson = pm.response.json();",
                      "const expectedId = pm.collectionVariables.get(\"createdProductId\");",
                      "",
                      "pm.test(\"Полученный ID товара совпадает с созданным ранее ID\", function () {",
                      "    pm.expect(responseJson.id).to.eql(expectedId);",
                      "});",
                      "",
                      "pm.test(\"Поля товара заполнены корректно\", function (){",
                      "    pm.expect(responseJson.title).to.be.a(\"string\");",
                      "    pm.expect(responseJson.price).to.be.a(\"number\");",
                      "    pm.expect(responseJson.images).to.be.an(\"array\");",
                      "});",
                      "",
                      ""
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/products/:id",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "products",
                    ":id"
                  ],
                  "variable": [
                    {
                      "key": "id",
                      "value": "{{createdProductId}}"
                    }
                  ]
                }
              },
              "response": []
            },
